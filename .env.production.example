# Sprint 10.5 template only. Do not commit real secrets.

# Routing / domains
PROXY_HTTP_PORT=80
API_LOCAL_PORT=8080
WORKER_LOCAL_PORT=8081
PUBLIC_WEB_HOST=tufflove.example.com
PUBLIC_API_HOST=api.tufflove.example.com
NEXT_PUBLIC_SITE_URL=https://tufflove.example.com
NEXT_PUBLIC_AGENT_API_URL=https://api.tufflove.example.com
CORS_ALLOW_ORIGINS=https://tufflove.example.com

# Auth / admin guards
ADMIN_TOKEN=replace_me_admin_token
AGENT_ADMIN_TOKEN=replace_me_admin_token
WORKER_ADMIN_TOKEN=replace_me_worker_token
FAMILYOPS_ADMIN_EMAILS=ops1@example.com,ops2@example.com

# OpenAI
OPENAI_API_KEY=replace_me_openai_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_FAST=
OPENAI_MODEL_REASONING=
OPENAI_TIMEOUT_SEC=30

# Supabase (current state; Sprint 11 will cut over)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me_supabase_anon
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me_supabase_service_role

# GHL OAuth (keep current behavior)
GHL_CLIENT_ID=replace_me
GHL_CLIENT_SECRET=replace_me
GHL_REDIRECT_URI=https://tufflove.example.com/api/ghl/callback
GHL_TOKEN_URL=https://services.leadconnectorhq.com/oauth/token

# Core service wiring
ENV=production
DATABASE_URL=postgresql://tufflove:replace_me_db_password@postgres:5432/tufflove
REDIS_URL=redis://redis:6379/0
WORKER_API_URL=http://worker:8081
DB_CONNECT_RETRIES=30
DB_CONNECT_DELAY_SEC=1
TRIGGER_DAILY_CAP_PER_TENANT=50
MAX_TASK_SECONDS=20

# Containerized Postgres defaults (if using compose-managed Postgres)
POSTGRES_USER=tufflove
POSTGRES_PASSWORD=replace_me_db_password
POSTGRES_DB=tufflove
