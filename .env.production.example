# TUFF LOVE production runtime template.
# Copy to .env.production on the server and set real secrets there.

# Core DB + queue
POSTGRES_USER=tufflove
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=tufflove

# API/worker auth gates
ADMIN_TOKEN=change_me_admin
WORKER_ADMIN_TOKEN=change_me_worker

# FamilyOps app-session auth
APP_AUTH_SECRET=change_me_app_auth_secret
FAMILYOPS_ADMIN_EMAILS=admin@example.com
FAMILYOPS_ADMIN_PASSWORD=change_me_familyops
APP_AUTH_SESSION_TTL_SECONDS=43200

# Web routing
NEXT_PUBLIC_SITE_URL=https://app.tufflove.us
NEXT_PUBLIC_AGENT_API_URL=http://api:8080
WORKER_API_URL=http://worker:8081
CORS_ALLOW_ORIGINS=https://app.tufflove.us

# LLM + publish connectors
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4o-mini
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_REDIRECT_URI=https://app.tufflove.us/api/ghl/callback
GHL_TOKEN_URL=https://services.leadconnectorhq.com/oauth/token

# Scheduler / runtime tuning
TRIGGER_DAILY_CAP=250
TRIGGER_SCHEDULER_INTERVAL_SEC=30
TRIGGER_SCHEDULER_DUE_LIMIT=50
WORKER_RUN_FOREVER_BLOCK_SECONDS=5
MAX_TASK_SECONDS=20
DB_CONNECT_RETRIES=60
DB_CONNECT_DELAY_SEC=1

# Optional Supabase fallback for legacy dashboard paths
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
